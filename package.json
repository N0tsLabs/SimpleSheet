{
  "name": "@n0ts123/simple-sheet",
  "version": "0.1.0",
  "type": "module",
  "description": "轻量级、零依赖的 Excel 风格表格框架",
  "main": "dist/simple-sheet.cjs.js",
  "module": "dist/simple-sheet.esm.js",
  "browser": "dist/simple-sheet.umd.js",
  "types": "dist/index.d.ts",
  "style": "dist/simple-sheet.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "cd dev && yarn dev",
    "dev:install": "cd dev && yarn install",
    "watch": "rollup -c -w",
    "build": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "spreadsheet",
    "excel",
    "table",
    "grid",
    "typescript",
    "vanilla"
  ],
  "author": "n0ts123",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "postcss": "^8.5.6",
    "postcss-import": "^16.0.0",
    "rollup": "^4.9.0",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/N0tsLabs/SimpleSheet.git"
  },
  "bugs": {
    "url": "https://github.com/N0tsLabs/SimpleSheet/issues"
  },
  "homepage": "https://github.com/N0tsLabs/SimpleSheet#readme",
  "publishConfig": {
    "access": "public"
  }
}
